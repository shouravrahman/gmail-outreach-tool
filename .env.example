# ============================================================================
# BULK EMAIL TOOL - ENVIRONMENT CONFIGURATION
# ============================================================================

# ----------------------------------------------------
# 1. CORE SECURITY (REQUIRED)
# ----------------------------------------------------
# Generate these using: openssl rand -hex 32
MASTER_KEY=your_32_byte_hex_master_key
ENCRYPTION_SALT=your_16_byte_hex_salt
JWT_SECRET=your_32_byte_hex_jwt_secret

# ----------------------------------------------------
# 2. DATABASE (REQUIRED)
# ----------------------------------------------------
# Connection string for PostgreSQL (Recommended for Production/Streamlit Cloud)
# Format: postgresql://user:password@host:port/dbname
# For local testing, you can leave this blank to use SQLite (bulk_email.db)
DATABASE_URL=

# ----------------------------------------------------
# 3. AI PROVIDERS (REQUIRED)
# ----------------------------------------------------
# Google Gemini (Recommended)
GOOGLE_API_KEY=your_gemini_api_key

# OpenAI (Optional)
OPENAI_API_KEY=sk-...

# Ollama (Optional - Local Only)
OLLAMA_BASE_URL=http://localhost:11434

# ----------------------------------------------------
# 4. INTEGRATIONS (OPTIONAL)
# ----------------------------------------------------
# Telegram Bot (For notifications and control)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google OAuth (For Gmail sending)
# Paste the content of client_secret.json as a single line
GOOGLE_CLIENT_JSON={"web":{"client_id":"...","client_secret":"...","auth_uri":"..."}}

# Resend (For transactional emails)
RESEND_API_KEY=re_...

# Redis (Optional)
# Used for rate limiting if available. Not required for single-instance Streamlit Cloud.
REDIS_URL=
