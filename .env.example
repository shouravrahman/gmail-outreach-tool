# 🛡️ 1. MASTER SECURITY KEY
# This key is used to encrypt your Google & Resend credentials in the DB.
# IMPORTANT: Change this to a long random string (e.g., 'v7b8n9m0p1q2r3s4t5u6v7w8x9y0z1a2').
MASTER_KEY=your_secret_encryption_key_here

# 📱 2. TELEGRAM BOT (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 📧 3. GOOGLE CLOUD OAUTH (Single-line escaped JSON)
# Download your OAuth Client JSON from Google Cloud Console.
# Paste the ENTIRE content here as A SINGLE LINE.
GOOGLE_CLIENT_JSON={"web":{"client_id":"...","client_secret":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","redirect_uris":["http://localhost:3001/api/auth/callback"]}}

# 🤖 4. AI MODELS
# Options: 'gemini', 'openai', or 'ollama'
AI_PROVIDER=gemini

# For Gemini (Cloud)
GOOGLE_API_KEY=your_gemini_api_key_here

# For OpenAI/OpenRouter (Cloud)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: Use OpenRouter
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# For Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434

# 📨 5. RESEND (Optional: for Custom Domains)
# Note: You can also link Resend keys directly through the Telegram bot
RESEND_API_KEY=re_your_api_key_here
